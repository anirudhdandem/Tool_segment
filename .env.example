PORT=4000

# ============================================================================
# MAPS-ONLY MODE. Leads come from a Google Maps scrape (Playwright).
# Enrichment chain for leads missing a real website: Tavily discovery search →
# Hunter / website mining.
# ============================================================================

# --- Google Maps scrape (PRIMARY source) ------------------------------------
# "true" enables the Playwright Google Maps scraper as the main lead source.
ENABLE_GOOGLE_MAPS=true
# Set "false" to watch the browser (debug consent walls / selector drift).
GMAPS_HEADLESS=true
# Concurrent place-detail page fetches (higher = faster but more anti-bot risk).
GMAPS_DETAIL_CONCURRENCY=4
# How many times to scroll the results feed (more = more listings).
GMAPS_SCROLLS=8

# --- Lead enrichment (turn ON for the full pipeline) ------------------------
# When "true", runs the enrichment chain: Tavily discovery → Hunter → website
# mining, adding email + contact-person + missing fields.
ENABLE_WEBSITE_ENRICHMENT=false

# --- Company profile (funding / company size / transaction volume) ----------
# When "true", per lead: Tavily fuses the web into one answer → Gemini
# structures it into the 3 fields. Needs GEMINI_API_KEY below.
ENABLE_COMPANY_PROFILE=true

# Gemini — the only LLM. Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# NOTE: every provider key EXCEPT Gemini is configured from the app UI
# (Settings → API Keys) and stored in backend/data/api-keys.json — NOT here.
# This covers Hunter.io, Tavily, Apollo.io and Resend.

# --- Auth & access control --------------------------------------------------
# Login/signup are restricted to this email domain.
AUTH_ALLOWED_DOMAIN=blostem.com
# Secret used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET=your-long-random-secret

# SMTP for transactional auth emails (OTP / 2FA codes). Google Workspace example.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@blostem.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=Prospio <you@blostem.com>

# --- Industry-news watcher (fintech + banking) ------------------------------
# Set ENABLE_NEWS_WATCHER=false to turn the whole watcher off.
ENABLE_NEWS_WATCHER=true
# Resend sender (key + recipients configured in the FRONTEND Settings → API Keys).
NEWS_EMAIL_FROM=Prospio News <onboarding@resend.dev>
